DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hostaway_analytics
REDIS_URL=redis://localhost:6379
NEXTAUTH_SECRET=replace-with-strong-random-secret
API_ENCRYPTION_KEY=replace-with-32-byte-base64-or-hex-key
HOSTAWAY_BASE_URL=https://api.hostaway.com
AIRROI_BASE_URL=https://api.airroi.com
AIRROI_API_KEY=[AIRROI_API_KEY]
AIRROI_CACHE_TTL_DAYS=14
ROOMY_ENABLE_LIVE_MARKET_REFRESH=false
HOSTAWAY_CLIENT_ID=[HOSTAWAY_CLIENT_ID]
HOSTAWAY_CLIENT_SECRET=[HOSTAWAY_CLIENT_SECRET]
HOSTAWAY_ACCOUNT_ID=[HOSTAWAY_ACCOUNT_ID]
WEBHOOK_BASIC_USER=[WEBHOOK_BASIC_USER]
WEBHOOK_BASIC_PASS=[WEBHOOK_BASIC_PASS]
APP_BASE_URL=http://localhost:3000
DATA_MODE=live
SAMPLE_CSV_PATH="/Users/markmccracken/Documents/Roomy Analytics/Sample Data/Escape Ordinary Sample Data.csv"
TENANT_DEFAULT_CURRENCY=GBP
DEFAULT_TIMEZONE=Europe/London
SEED_TENANT_ID=tenant_demo
SAMPLE_TENANT_ID=tenant_demo
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-password

# KeyData market-data trial (Belfast only — Stay Belfast + Little Feather)
# https://developer.keydatadashboard.com/
KEYDATA_API_BASE_URL=https://api-beta.keydatadashboard.com
KEYDATA_ACCESS_KEY=
# Optional second key if KeyData issues separate PM/OTA keys (provider falls
# back to KEYDATA_ACCESS_KEY when this is unset).
KEYDATA_OTA_ACCESS_KEY=
KEYDATA_TRIAL_MODE=belfast-only
KEYDATA_TRIAL_TENANTS=stay-belfast,little-feather
# Comma-separated tenant CUIDs that override the slug match above when set.
KEYDATA_TRIAL_TENANT_IDS=
KEYDATA_TRIAL_START=2026-05-18
KEYDATA_TRIAL_END=2026-06-01
KEYDATA_DAILY_CALL_BUDGET=25
# Populated by the provider on first lookup; set manually to skip the lookup.
KEYDATA_BELFAST_MARKET_UUID=
# Demand-spike classifier thresholds (used by the divergence-cause module).
# A cell is labelled demand_spike_caught/missed when BOTH thresholds are
# cleared on the KeyData YoY signals for that target date. Defaults are
# deliberately conservative — designed for clear event-driven spikes
# (Fleadh, Halloween, NYE). Lower to ~0.08 each to catch softer spikes
# at the cost of more false positives.
KEYDATA_SPIKE_OCC_YOY_PP=0.15
KEYDATA_SPIKE_ADR_YOY_PCT=0.15

# Daily trial reports
RESEND_API_KEY=
TRIAL_REPORT_EMAIL_FROM=trial-reports@signals.roomyrevenue.com
TRIAL_REPORT_EMAIL_TO=mark@roomyrevenue.com

# Defensibility audit (Anthropic Claude)
ANTHROPIC_API_KEY=

# Signals rate scanner — read-only monthly-summary endpoint.
# Gates GET /api/signals/monthly-summary. When unset (the default) the route
# returns 404 and the endpoint is effectively disabled. Set to a long random
# token to enable it, then pass it as ?key=<token>. Read nowhere else.
SIGNALS_SUMMARY_KEY=

# =============================================================================
# Observe-and-Learn pricing intelligence (see /SIGNALS-OBSERVE-LEARN-SPEC.md).
# Read-only. Keys are read from these env vars OR from a plain-text file at
# OBSERVE_KEYS_FILE (one KEY=value per line). NEVER commit a key value here.
# Key/engine env-var suffix <S> = UPPER_SNAKE of the tenant name. The registry
# matches by segment-prefix (longest wins), so a short suffix resolves a longer
# tenant name: PRICELABS_KEY_STAY_BELFAST matches "Stay Belfast Apartments", and
# OBSERVE_ENGINE_COORIE_DOON matches "Coorie Doon Stays". Engine pin
# OBSERVE_ENGINE_<S> ∈ {pricelabs, wheelhouse, hostaway-scan}; when unset it is
# inferred from which key is present, defaulting to hostaway-scan.
# (Dev-DB tenant names verified 2026-06-26: "Escape Ordinary",
# "Stay Belfast Apartments", "Little Feather Management", "Coorie Doon Stays".)
# -----------------------------------------------------------------------------
# Optional: point at the supplied RMS keys file instead of setting each key var.
OBSERVE_KEYS_FILE=
# PriceLabs read keys (X-API-Key). One per client; scopes to that client.
PRICELABS_KEY_ESCAPE_ORDINARY=
PRICELABS_KEY_STAY_BELFAST=
PRICELABS_KEY_LITTLE_FEATHER=
# Wheelhouse read key (X-Integration-Api-Key). Coorie Doon's key 401s today, so
# Coorie Doon is pinned to the hostaway-scan fallback below (spec §2).
WHEELHOUSE_KEY_COORIE_DOON=
# Engine pins (per spec §2 verified routing). Escape Ordinary / Stay Belfast /
# Little Feather default to pricelabs once their key is set; Coorie Doon stays on
# the Hostaway-scan fallback until a valid Wheelhouse read key is supplied.
OBSERVE_ENGINE_ESCAPE_ORDINARY=pricelabs
OBSERVE_ENGINE_STAY_BELFAST=pricelabs
OBSERVE_ENGINE_LITTLE_FEATHER=pricelabs
OBSERVE_ENGINE_COORIE_DOON=hostaway-scan
# Optional base-URL overrides (default to the public engine hosts).
PRICELABS_BASE_URL=https://api.pricelabs.co/v1
WHEELHOUSE_BASE_URL=https://api.usewheelhouse.com/ss_api/v1
# Read-only key-gated routes for the day-30 readout + suggestions (Phase 4).
# 404 when unset, like SIGNALS_SUMMARY_KEY. Pass as ?key=<token>.
OBSERVE_READOUT_KEY=
