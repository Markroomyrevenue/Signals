generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                         String                      @id @default(cuid())
  name                       String
  defaultCurrency            String                      @map("default_currency") @db.VarChar(3)
  timezone                   String                      @default("Europe/London")
  pmsType                    String                      @default("HOSTAWAY") @map("pms_type")
  createdAt                  DateTime                    @default(now()) @map("created_at")
  users                      User[]
  sessions                   Session[]
  hostaway                   HostawayConnection?
  avantio                    AvantioConnection?
  listings                   Listing[]
  reservations               Reservation[]
  calendarRates              CalendarRate[]
  nightFacts                 NightFact[]
  paceSnapshots              PaceSnapshot[]
  dailyAggs                  DailyAgg[]
  syncRuns                   SyncRun[]
  attentionTaskSuppressions  AttentionTaskSuppression[]
  pricingSettings            PricingSetting[]
  hostawayPushEvents         HostawayPushEvent[]
  pricingComparisonSnapshots PricingComparisonSnapshot[]
  pricingComparisonRuns      PricingComparisonRun[]
  pricingBacktestResults     PricingBacktestResult[]
  pricingDefensibilityAudits PricingDefensibilityAudit[]
  pricingManualOverrides     PricingManualOverride[]
  rateScans                  RateScan[]
  rateStates                 RateState[]
  rateChanges                RateChange[]
  bookingRateContexts        BookingRateContext[]

  @@map("tenants")
}

model PricingSetting {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  scope     String
  scopeRef  String?  @map("scope_ref")
  settings  Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, scope, scopeRef])
  @@index([tenantId, scope])
  @@map("pricing_settings")
}

model ExternalApiCache {
  id           String   @id @default(cuid())
  provider     String
  cacheKey     String   @map("cache_key")
  requestLabel String?  @map("request_label")
  status       String
  payload      Json?
  errorMessage String?  @map("error_message")
  fetchedAt    DateTime @map("fetched_at")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([provider, cacheKey])
  @@index([provider, expiresAt])
  @@map("external_api_cache")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  email        String
  passwordHash String    @map("password_hash")
  // role: "admin" sees Calendar/pricing + team management; "viewer" is reporting-only staff.
  role         String    @default("viewer")
  displayName  String?   @map("display_name")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions     Session[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([tenantId, role])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([expiresAt])
  @@map("sessions")
}

model HostawayConnection {
  tenantId                      String    @id @map("tenant_id")
  hostawayAccountId             String?   @map("hostaway_account_id")
  apiKeyEncrypted               String?   @map("api_key_encrypted")
  hostawayClientId              String?   @map("hostaway_client_id")
  hostawayClientSecretEncrypted String?   @map("hostaway_client_secret_encrypted")
  hostawayAccessTokenEncrypted  String?   @map("hostaway_access_token_encrypted")
  hostawayAccessTokenExpiresAt  DateTime? @map("hostaway_access_token_expires_at")
  webhookBasicUser              String?   @map("webhook_basic_user")
  webhookBasicPassEncrypted     String?   @map("webhook_basic_pass_encrypted")
  createdAt                     DateTime  @default(now()) @map("created_at")
  updatedAt                     DateTime  @updatedAt @map("updated_at")
  lastSyncAt                    DateTime? @map("last_sync_at")
  status                        String    @default("active")
  webhookSharedToken            String?   @map("webhook_shared_token")
  tenant                        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("hostaway_connections")
}

/// Avantio PMS credentials. Mirrors HostawayConnection shape so a Tenant
/// with pmsType="AVANTIO" can hold its API key + base URL + last-sync
/// timestamp the same way a Hostaway tenant does. One row per tenant.
model AvantioConnection {
  tenantId        String    @id @map("tenant_id")
  apiKeyEncrypted String?   @map("api_key_encrypted")
  baseUrl         String    @default("https://api.avantio.pro/pms") @map("base_url")
  companyId       String?   @map("company_id")
  status          String    @default("active")
  lastSyncAt      DateTime? @map("last_sync_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("avantio_connections")
}

model Listing {
  id                        String                     @id @default(cuid())
  tenantId                  String                     @map("tenant_id")
  hostawayId                String                     @map("hostaway_id")
  name                      String
  externalName              String?                    @map("external_name")
  status                    String
  timezone                  String
  tags                      String[]                   @default([])
  country                   String?
  countryCode               String?                    @map("country_code")
  state                     String?
  city                      String?
  street                    String?
  address                   String?
  publicAddress             String?                    @map("public_address")
  postalCode                String?                    @map("postal_code")
  latitude                  Decimal?                   @db.Decimal(10, 7)
  longitude                 Decimal?                   @db.Decimal(10, 7)
  roomType                  String?                    @map("room_type")
  propertyTypeId            Int?                       @map("property_type_id")
  bedroomsNumber            Int?                       @map("bedrooms_number")
  bathroomsNumber           Decimal?                   @map("bathrooms_number") @db.Decimal(8, 2)
  bedsNumber                Int?                       @map("beds_number")
  personCapacity            Int?                       @map("person_capacity")
  // unitCount: when null, this is a single-unit listing (the default).
  // When >= 2, this Hostaway listing represents N rooms of the same type
  // (e.g. "Double Studio × 20"). Multi-unit pricing logic uses a
  // lead-time × occupancy matrix instead of the standard occupancy
  // multiplier, and the calendar UI renders a distinct row treatment.
  unitCount                 Int?                       @map("unit_count")
  guestsIncluded            Int?                       @map("guests_included")
  minNights                 Int?                       @map("min_nights")
  maxNights                 Int?                       @map("max_nights")
  cleaningFee               Decimal?                   @map("cleaning_fee") @db.Decimal(18, 6)
  // vatRatePct: the listing's mandatory percent VAT rate (e.g. 20 = 20%),
  // derived from the Hostaway listingFeeSetting at sync time. Null when the
  // listing has no mandatory percent VAT/tax fee. Stored revenue is always
  // VAT-inclusive (gross); this rate lets reports impute and optionally strip
  // the VAT portion for the Inc/Ex-VAT toggle. See src/lib/sync/listing-vat.ts.
  vatRatePct                Decimal?                   @map("vat_rate_pct") @db.Decimal(6, 3)
  currencyCode              String?                    @map("currency_code") @db.VarChar(3)
  averageReviewRating       Decimal?                   @map("average_review_rating") @db.Decimal(8, 2)
  thumbnailUrl              String?                    @map("thumbnail_url")
  airbnbListingUrl          String?                    @map("airbnb_listing_url")
  vrboListingUrl            String?                    @map("vrbo_listing_url")
  rawJson                   Json?                      @map("raw_json")
  // removedAt: set when a successful, non-empty Hostaway listing sync no
  // longer returns this listing (deleted/moved out of the account). The
  // row and all its history are kept; the listing is just hidden from the
  // app. Cleared back to null if the listing reappears in a later sync.
  removedAt                 DateTime?                  @map("removed_at")
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations              Reservation[]
  calendarRates             CalendarRate[]
  nightFacts                NightFact[]
  paceSnapshots             PaceSnapshot[]
  dailyAggs                 DailyAgg[]
  attentionTaskSuppressions AttentionTaskSuppression[]
  hostawayPushEvents        HostawayPushEvent[]
  pricingManualOverrides    PricingManualOverride[]
  rateStates                RateState[]
  rateChanges               RateChange[]
  bookingRateContexts       BookingRateContext[]

  // hostawayId holds the external PMS id (Hostaway or Avantio) per tenant.pmsType.
  @@unique([tenantId, hostawayId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, timezone])
  @@index([tenantId, removedAt])
  @@map("listings")
}

model HostawayPushEvent {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  listingId     String   @map("listing_id")
  pushedBy      String   @map("pushed_by")
  dateFrom      DateTime @map("date_from") @db.Date
  dateTo        DateTime @map("date_to") @db.Date
  dateCount     Int      @map("date_count")
  status        String
  errorMessage  String?  @map("error_message")
  payload       Json
  // 'manual' = user clicked "Push live rates" or "Push now"; 'scheduled' =
  // daily rate-copy worker. Defaults to 'scheduled' so historical rows
  // (which we don't have explicit context on) read as routine.
  triggerSource String   @default("scheduled") @map("trigger_source")
  // FK-style reference to PricingManualOverride.id when the pushed rate
  // reflected an active override at push time. Most pushes are null.
  overrideId    String?  @map("override_id")
  createdAt     DateTime @default(now()) @map("created_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([tenantId, listingId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, triggerSource, createdAt(sort: Desc)])
  @@index([overrideId])
  @@map("hostaway_push_events")
}

/// Manual price override on a (listing × date-range). Created via the bulk
/// "Bulk edit overrides" modal at the top of the pricing calendar. Soft-
/// deleted via `removedAt` so audit history is preserved. Two override
/// types:
///   - `'fixed'`: replaces the rate entirely. Min floor does NOT apply.
///   - `'percentage_delta'`: applied multiplicatively on top of the
///     dynamic recommendation. Min floor still applies.
/// Optional `minStay` overrides the listing's default min-stay for the
/// pushed dates (only honoured for listings that push to Hostaway).
model PricingManualOverride {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  listingId     String    @map("listing_id")
  startDate     DateTime  @map("start_date") @db.Date
  endDate       DateTime  @map("end_date") @db.Date
  overrideType  String    @map("override_type")
  overrideValue Float     @map("override_value")
  minStay       Int?      @map("min_stay")
  notes         String?
  createdBy     String    @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  removedAt     DateTime? @map("removed_at")
  removedBy     String?   @map("removed_by")
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing       Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([tenantId, listingId, startDate, endDate])
  @@index([tenantId, listingId, removedAt])
  @@map("pricing_manual_overrides")
}

model AttentionTaskSuppression {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  listingId       String   @map("listing_id")
  taskKey         String   @map("task_key")
  action          String
  suppressedUntil DateTime @map("suppressed_until")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([tenantId, listingId, taskKey])
  @@index([tenantId, suppressedUntil])
  @@index([tenantId, listingId])
  @@map("attention_task_suppressions")
}

model Reservation {
  id                String      @id @default(cuid())
  tenantId          String      @map("tenant_id")
  hostawayId        String      @map("hostaway_id")
  listingId         String      @map("listing_id")
  channel           String?
  status            String
  createdAt         DateTime    @map("created_at")
  confirmedAt       DateTime?   @map("confirmed_at")
  arrival           DateTime    @db.Date
  departure         DateTime    @db.Date
  nights            Int
  guests            Int?
  currency          String      @db.VarChar(3)
  total             Decimal     @db.Decimal(18, 6)
  accommodationFare Decimal     @map("accommodation_fare") @db.Decimal(18, 6)
  cleaningFee       Decimal     @map("cleaning_fee") @db.Decimal(18, 6)
  guestFee          Decimal     @default(0) @map("guest_fee") @db.Decimal(18, 6)
  taxes             Decimal     @db.Decimal(18, 6)
  commission        Decimal     @db.Decimal(18, 6)
  cancelledAt       DateTime?   @map("cancelled_at")
  sourceUpdatedAt   DateTime?   @map("source_updated_at")
  rawJson           Json        @map("raw_json")
  ingestedAt        DateTime    @default(now()) @map("ingested_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing           Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  nightFacts        NightFact[]

  // hostawayId holds the external PMS id (Hostaway or Avantio) per tenant.pmsType.
  @@unique([tenantId, hostawayId])
  @@index([tenantId, createdAt])
  @@index([tenantId, arrival])
  @@index([tenantId, departure])
  @@index([tenantId, hostawayId])
  @@index([tenantId, channel])
  @@index([tenantId, status])
  @@index([tenantId, listingId, arrival, departure])
  @@index([tenantId, sourceUpdatedAt])
  @@map("reservations")
}

model CalendarRate {
  tenantId  String   @map("tenant_id")
  listingId String   @map("listing_id")
  date      DateTime @db.Date
  available Boolean
  minStay   Int?     @map("min_stay")
  maxStay   Int?     @map("max_stay")
  rate      Decimal  @db.Decimal(18, 6)
  currency  String   @db.VarChar(3)
  updatedAt DateTime @map("updated_at")
  rawJson   Json     @map("raw_json")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([tenantId, listingId, date])
  @@index([tenantId, listingId, date])
  @@index([tenantId, date])
  @@map("calendar_rates")
}

model NightFact {
  tenantId         String       @map("tenant_id")
  listingId        String       @map("listing_id")
  date             DateTime     @db.Date
  factKey          String       @map("fact_key")
  reservationId    String?      @map("reservation_id")
  isOccupied       Boolean      @map("is_occupied")
  revenueAllocated Decimal      @map("revenue_allocated") @db.Decimal(18, 6)
  currency         String       @db.VarChar(3)
  channel          String?
  bookingCreatedAt DateTime?    @map("booking_created_at")
  leadTimeDays     Int?         @map("lead_time_days")
  losNights        Int?         @map("los_nights")
  status           String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing          Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reservation      Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@id([tenantId, date, listingId, factKey])
  @@index([tenantId, date])
  @@index([tenantId, listingId, date])
  @@index([tenantId, bookingCreatedAt])
  @@index([tenantId, channel])
  @@index([tenantId, status])
  @@index([tenantId, reservationId])
  @@map("night_facts")
}

model PaceSnapshot {
  tenantId       String   @map("tenant_id")
  snapshotDate   DateTime @map("snapshot_date") @db.Date
  listingId      String   @map("listing_id")
  stayDate       DateTime @map("stay_date") @db.Date
  nightsOnBooks  Int      @map("nights_on_books")
  revenueOnBooks Decimal  @map("revenue_on_books") @db.Decimal(18, 6)
  currency       String   @db.VarChar(3)
  createdAt      DateTime @default(now()) @map("created_at")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing        Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([tenantId, snapshotDate, listingId, stayDate])
  @@index([tenantId, snapshotDate, stayDate])
  @@index([tenantId, listingId, snapshotDate])
  @@map("pace_snapshots")
}

model DailyAgg {
  tenantId          String   @map("tenant_id")
  listingId         String   @map("listing_id")
  date              DateTime @db.Date
  occupiedNights    Int      @default(0) @map("occupied_nights")
  availableNights   Int      @default(0) @map("available_nights")
  stayRevenue       Decimal  @default(0) @map("stay_revenue") @db.Decimal(18, 6)
  bookingsCreated   Int      @default(0) @map("bookings_created")
  bookedRevenue     Decimal  @default(0) @map("booked_revenue") @db.Decimal(18, 6)
  cancellationCount Int      @default(0) @map("cancellation_count")
  liveRateAvg       Decimal? @map("live_rate_avg") @db.Decimal(18, 6)
  currency          String   @db.VarChar(3)
  updatedAt         DateTime @updatedAt @map("updated_at")
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([tenantId, listingId, date])
  @@index([tenantId, date])
  @@index([tenantId, listingId, date])
  @@map("daily_aggs")
}

model FxRate {
  date          DateTime @db.Date
  baseCurrency  String   @map("base_currency") @db.VarChar(3)
  quoteCurrency String   @map("quote_currency") @db.VarChar(3)
  rate          Decimal  @db.Decimal(18, 8)
  source        String?
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@id([date, baseCurrency, quoteCurrency])
  @@index([baseCurrency, quoteCurrency, date])
  @@map("fx_rates")
}

model SyncRun {
  id           String    @id @default(cuid())
  tenantId     String    @map("tenant_id")
  jobType      String    @map("job_type")
  status       String
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  errorMessage String?   @map("error_message")
  details      Json?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, status, finishedAt])
  @@index([tenantId, jobType])
  @@map("sync_runs")
}

// ============================================================================
// KeyData trial (added 2026-04-28; see /BUILD-LOG.md). Five tables.
// All five filter by tenantId per the multi-tenant isolation rule in CLAUDE.md.
// ============================================================================

model KeyDataCacheEntry {
  cacheKey   String   @id @map("cache_key")
  payload    Json
  fetchedAt  DateTime @map("fetched_at")
  expiresAt  DateTime @map("expires_at")
  sampleSize Int?     @map("sample_size")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("keydata_cache_entries")
}

model PricingComparisonRun {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  snapshotDate      DateTime  @map("snapshot_date") @db.Date
  startedAt         DateTime  @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  status            String // running | succeeded | failed
  listingsProcessed Int       @default(0) @map("listings_processed")
  cellsCompared     Int       @default(0) @map("cells_compared")
  errorsCount       Int       @default(0) @map("errors_count")
  errorMessage      String?   @map("error_message")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, snapshotDate])
  @@index([tenantId, status])
  @@map("pricing_comparison_runs")
}

model PricingComparisonSnapshot {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  snapshotDate   DateTime @map("snapshot_date") @db.Date
  listingId      String   @map("listing_id")
  targetDate     DateTime @map("target_date") @db.Date
  ourRate        Decimal  @map("our_rate") @db.Decimal(18, 6)
  hostawayRate   Decimal? @map("hostaway_rate") @db.Decimal(18, 6)
  deltaAbs       Decimal? @map("delta_abs") @db.Decimal(18, 6)
  deltaPct       Float?   @map("delta_pct")
  windowDays     Int      @map("window_days") // days from snapshotDate to targetDate
  classification String // agree | our_higher | our_lower | no_hostaway_rate
  ourBreakdown   Json     @map("our_breakdown")
  // Divergence-cause classifier fields (populated when |deltaPct| > 5%).
  // `null` when the cell is in agreement or PriceLabs has no live rate.
  divergenceCause      String? @map("divergence_cause") // occupancy_driven | demand_disagreement | level_disagreement | mixed | null
  ourLift              Float?  @map("our_lift") // (ourRate - ourBaseline_±14d) / ourBaseline
  plLift               Float?  @map("pl_lift") // (plRate - plBaseline_±14d) / plBaseline
  liftDelta            Float?  @map("lift_delta") // ourLift - plLift
  // Occupancy fields powering the `occupancy_driven` classification.
  // ourOccupancyMultiplier == breakdown.occupancy at compute time.
  // rateWithoutOccupancy = ourRate / ourOccupancyMultiplier (what we'd
  // have recommended without the occupancy lift) — surfaced so the
  // report can show "occupancy lift accounts for £X of this divergence".
  ourOccupancyMultiplier Float?   @map("our_occupancy_multiplier")
  rateWithoutOccupancy   Decimal? @map("rate_without_occupancy") @db.Decimal(18, 6)
  keyDataForwardOcc          Float?  @map("keydata_forward_occ") // KeyData market occupancy at this target date
  keyDataForwardAdr          Float?  @map("keydata_forward_adr") // KeyData market ADR at this target date
  keyDataForwardOccLy        Float?  @map("keydata_forward_occ_ly") // same date - 365d
  keyDataForwardAdrLy        Float?  @map("keydata_forward_adr_ly")
  // RevPar adjusted by KeyData (filters outlier rates) — more stable
  // than raw ADR × occ for trend detection.
  keyDataForwardRevparAdj    Float?  @map("keydata_forward_revpar_adj")
  keyDataForwardRevparAdjLy  Float?  @map("keydata_forward_revpar_adj_ly")
  // Average booking window in days. Used as a leading indicator: when
  // significantly above the 13-week trailing median for the market,
  // booking pressure for this date is unusual = likely event.
  keyDataForwardBookingWindow       Float? @map("keydata_forward_booking_window")
  keyDataForwardBookingWindowMedian Float? @map("keydata_forward_booking_window_median")
  createdAt      DateTime @default(now()) @map("created_at")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, snapshotDate])
  @@index([tenantId, listingId, targetDate])
  @@index([tenantId, snapshotDate, classification])
  @@index([tenantId, snapshotDate, divergenceCause])
  @@map("pricing_comparison_snapshots")
}

model PricingBacktestResult {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  runId          String   @map("run_id") // groups results from a single backtest run
  listingId      String   @map("listing_id")
  stayDate       DateTime @map("stay_date") @db.Date
  bookedAdr      Decimal? @map("booked_adr") @db.Decimal(18, 6)
  recommendedAdr Decimal? @map("recommended_adr") @db.Decimal(18, 6)
  absError       Decimal? @map("abs_error") @db.Decimal(18, 6)
  pctError       Float?   @map("pct_error")
  bookingCount   Int      @default(0) @map("booking_count")
  notes          Json?
  createdAt      DateTime @default(now()) @map("created_at")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, runId])
  @@index([tenantId, runId, stayDate])
  @@index([tenantId, listingId, stayDate])
  @@map("pricing_backtest_results")
}

model PricingDefensibilityAudit {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  snapshotDate    DateTime @map("snapshot_date") @db.Date
  listingId       String   @map("listing_id")
  targetDate      DateTime @map("target_date") @db.Date
  verdict         String // defensible | borderline | questionable
  confidence      Float
  keyStrengths    Json     @map("key_strengths")
  keyConcerns     Json     @map("key_concerns")
  questionableMul String   @map("questionable_multiplier")
  fullReasoning   String   @map("full_reasoning")
  createdAt       DateTime @default(now()) @map("created_at")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, snapshotDate, verdict])
  @@index([tenantId, snapshotDate, listingId])
  @@map("pricing_defensibility_audits")
}

// ---------------------------------------------------------------------------
// Signals rate scanner (see /SIGNALS-RATE-SCAN-SPEC.md).
//
// Four NEW tables only. The scanner is read-only with respect to the rest of
// the tool: it records how live Hostaway rates move over time and writes
// nowhere else. Every model carries tenantId and @@index([tenantId, ...]) for
// multi-tenant isolation, and cascades from tenants/listings like the existing
// models.
// ---------------------------------------------------------------------------

model RateScan {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  scannedAt    DateTime @default(now()) @map("scanned_at")
  trigger      String // scheduled | manual
  status       String // success | partial | failed
  listingCount Int      @map("listing_count")
  changeCount  Int      @map("change_count")
  failedCount  Int      @map("failed_count")
  error        String?
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, scannedAt])
  @@map("rate_scans")
}

model RateState {
  tenantId   String   @map("tenant_id")
  listingId  String   @map("listing_id")
  date       DateTime @db.Date
  rate       Decimal  @db.Decimal(18, 6)
  minStay    Int?     @map("min_stay")
  available  Boolean
  currency   String   @db.VarChar(3)
  lastScanId String   @map("last_scan_id")
  updatedAt  DateTime @updatedAt @map("updated_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([tenantId, listingId, date])
  @@index([tenantId, listingId, date])
  @@map("rate_states")
}

model RateChange {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  listingId       String   @map("listing_id")
  date            DateTime @db.Date
  scanId          String   @map("scan_id")
  lever           String // price | min_stay | availability
  oldValue        Decimal? @map("old_value") @db.Decimal(18, 6)
  newValue        Decimal? @map("new_value") @db.Decimal(18, 6)
  changePct       Decimal? @map("change_pct") @db.Decimal(10, 4)
  yearlyAdrMedian Decimal? @map("yearly_adr_median") @db.Decimal(18, 6)
  pctOfYearlyAdr  Decimal? @map("pct_of_yearly_adr") @db.Decimal(10, 4)
  detectedAt      DateTime @default(now()) @map("detected_at")
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([tenantId, listingId, date])
  @@index([tenantId, detectedAt])
  @@index([tenantId, lever])
  @@map("rate_changes")
}

model BookingRateContext {
  id               String   @id @default(cuid())
  tenantId         String   @map("tenant_id")
  listingId        String   @map("listing_id")
  reservationId    String   @map("reservation_id")
  stayDate         DateTime @map("stay_date") @db.Date
  rateChangeId     String?  @map("rate_change_id")
  bookingCreatedAt DateTime @map("booking_created_at")
  hoursSinceChange Decimal? @map("hours_since_change") @db.Decimal(10, 4)
  leverChanged     String?  @map("lever_changed")
  createdAt        DateTime @default(now()) @map("created_at")
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([tenantId, reservationId, stayDate, rateChangeId])
  @@index([tenantId, listingId, stayDate])
  @@index([tenantId, bookingCreatedAt])
  @@map("booking_rate_contexts")
}
